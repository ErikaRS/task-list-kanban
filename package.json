{
	"name": "task-list-kanban",
	"version": "2.13.0",
	"description": "Kanban plugin to create task lists",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && npm run check:svelte && node esbuild.config.mjs production",
		"check:svelte": "svelte-check --tsconfig tsconfig.json --threshold error",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@smui-extra/autocomplete": "^8.0.3",
		"@tsconfig/svelte": "^5.0.4",
		"@types/crypto-js": "^4.2.2",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^20.12.12",
		"@typescript-eslint/eslint-plugin": "7.10.0",
		"@typescript-eslint/parser": "7.10.0",
		"builtin-modules": "4.0.0",
		"esbuild": "^0.28.1",
		"esbuild-svelte": "^0.8.1",
		"obsidian": "latest",
		"svelte": "^5.56.0",
		"svelte-check": "^4.7.1",
		"svelte-preprocess": "^5.1.4",
		"tslib": "2.6.2",
		"typescript": "5.4.5",
		"vite": "^8.0.16",
		"vitest": "^4.1.0"
	},
	"overrides": {
		"flatted": ">=3.4.2"
	},
	"dependencies": {
		"crypto-js": "^4.2.0",
		"esbuild-sass-plugin": "^3.3.0",
		"js-yaml": "^4.2.0",
		"sass": "^1.77.2",
		"svelte-select": "^5.8.3",
		"zod": "^3.23.8"
	}
}
